rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        (request.auth.token.email == "acosmetic.es@gmail.com" && request.auth.token.email_verified == true)
      );
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['user', 'admin'];
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'price', 'category', 'image']) &&
             data.name is string && data.name.size() < 200 &&
             data.price is number && data.price >= 0 &&
             data.category is string &&
             data.image is string;
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['userId', 'items', 'total', 'status', 'createdAt', 'shippingAddress']) &&
             data.userId == request.auth.uid &&
             data.total is number && data.total >= 0 &&
             data.status in ['pending', 'processing', 'shipped', 'delivered'] &&
             data.shippingAddress is string && data.shippingAddress.size() > 0;
    }

    // Rules
    match /test/connection {
      allow read: if true;
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.role == 'user';
      allow update: if (isOwner(userId) && request.resource.data.role == resource.data.role) || isAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin() && isValidProduct(request.resource.data);
    }

    match /orders/{orderId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isAuthenticated() && isValidOrder(request.resource.data);
      allow update: if isAdmin();
      allow delete: if false;
    }
  }
}
